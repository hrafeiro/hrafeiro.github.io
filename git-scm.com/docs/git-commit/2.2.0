<a href='/docs/git-rm'>git-rm[1]</a>,
<a href='/docs/git-mv'>git-mv[1]</a>,
<a href='/docs/git-merge'>git-merge[1]</a>,
<a href='/docs/git-commit-tree'>git-commit-tree[1]</a></p>
</div></div>
</div>

