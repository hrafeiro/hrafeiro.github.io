<code class="go">    deleted:    PROJECTS.md</code>
</pre>

<p>–ü–ĺ—Ā–Ľ–Ķ —Ā–Ľ–Ķ–ī—É—é—Č–Ķ–≥–ĺ –ļ–ĺ–ľ–ľ–ł—ā–į —Ą–į–Ļ–Ľ –ł—Ā—á–Ķ–∑–Ĺ–Ķ—ā –ł –Ī–ĺ–Ľ—Ć—ą–Ķ –Ĺ–Ķ –Ī—É–ī–Ķ—ā –ĺ—ā—Ā–Ľ–Ķ–∂–ł–≤–į—ā—Ć—Ā—Ź. –ē—Ā–Ľ–ł –≤—č –ł–∑–ľ–Ķ–Ĺ–ł–Ľ–ł —Ą–į–Ļ–Ľ –ł —É–∂–Ķ –Ņ—Ä–ĺ–ł–Ĺ–ī–Ķ–ļ—Ā–ł—Ä–ĺ–≤–į–Ľ–ł –Ķ–≥–ĺ, –≤—č –ī–ĺ–Ľ–∂–Ĺ—č –ł—Ā–Ņ–ĺ–Ľ—Ć–∑–ĺ–≤–į—ā—Ć –Ņ—Ä–ł–Ĺ—É–ī–ł—ā–Ķ–Ľ—Ć–Ĺ–ĺ–Ķ —É–ī–į–Ľ–Ķ–Ĺ–ł–Ķ —Ā –Ņ–ĺ–ľ–ĺ—Č—Ć—é –Ņ–į—Ä–į–ľ–Ķ—ā—Ä–į <code>-f</code>. –≠—ā–ĺ —Ā–ī–Ķ–Ľ–į–Ĺ–ĺ –ī–Ľ—Ź –Ņ–ĺ–≤—č—ą–Ķ–Ĺ–ł—Ź –Ī–Ķ–∑–ĺ–Ņ–į—Ā–Ĺ–ĺ—Ā—ā–ł, —á—ā–ĺ–Ī—č –Ņ—Ä–Ķ–ī–ĺ—ā–≤—Ä–į—ā–ł—ā—Ć –ĺ—ą–ł–Ī–ĺ—á–Ĺ–ĺ–Ķ —É–ī–į–Ľ–Ķ–Ĺ–ł–Ķ –ī–į–Ĺ–Ĺ—č—Ö, –ļ–ĺ—ā–ĺ—Ä—č–Ķ –Ķ—Č—Ď –Ĺ–Ķ –Ī—č–Ľ–ł –∑–į–Ņ–ł—Ā–į–Ĺ—č –≤ —Ā–Ĺ–ł–ľ–ĺ–ļ —Ā–ĺ—Ā—ā–ĺ—Ź–Ĺ–ł—Ź –ł –ļ–ĺ—ā–ĺ—Ä—č–Ķ –Ĺ–Ķ–Ľ—Ć–∑—Ź –≤–ĺ—Ā—Ā—ā–į–Ĺ–ĺ–≤–ł—ā—Ć –ł–∑ Git.</p>

<p>–Ē—Ä—É–≥–į—Ź –Ņ–ĺ–Ľ–Ķ–∑–Ĺ–į—Ź —ą—ā—É–ļ–į, –ļ–ĺ—ā–ĺ—Ä—É—é –≤—č –ľ–ĺ–∂–Ķ—ā–Ķ –∑–į—Ö–ĺ—ā–Ķ—ā—Ć —Ā–ī–Ķ–Ľ–į—ā—Ć ‚ÄĒ —ć—ā–ĺ —É–ī–į–Ľ–ł—ā—Ć —Ą–į–Ļ–Ľ –ł–∑ –ł–Ĺ–ī–Ķ–ļ—Ā–į, –ĺ—Ā—ā–į–≤–ł–≤ –Ķ–≥–ĺ –Ņ—Ä–ł —ć—ā–ĺ–ľ –≤ —Ä–į–Ī–ĺ—á–Ķ–ľ –ļ–į—ā–į–Ľ–ĺ–≥–Ķ. –Ē—Ä—É–≥–ł–ľ–ł —Ā–Ľ–ĺ–≤–į–ľ–ł, –≤—č –ľ–ĺ–∂–Ķ—ā–Ķ –∑–į—Ö–ĺ—ā–Ķ—ā—Ć –ĺ—Ā—ā–į–≤–ł—ā—Ć —Ą–į–Ļ–Ľ –Ĺ–į –≤–ł–Ĺ—á–Ķ—Ā—ā–Ķ—Ä–Ķ, –ł —É–Ī—Ä–į—ā—Ć –Ķ–≥–ĺ –ł–∑-–Ņ–ĺ–ī –Ī–ī–ł—ā–Ķ–Ľ—Ć–Ĺ–ĺ–≥–ĺ –ĺ–ļ–į Git. –≠—ā–ĺ –ĺ—Ā–ĺ–Ī–Ķ–Ĺ–Ĺ–ĺ –Ņ–ĺ–Ľ–Ķ–∑–Ĺ–ĺ, –Ķ—Ā–Ľ–ł –≤—č –∑–į–Ī—č–Ľ–ł –ī–ĺ–Ī–į–≤–ł—ā—Ć —á—ā–ĺ-—ā–ĺ –≤ —Ą–į–Ļ–Ľ <code>.gitignore</code> –ł –Ņ–ĺ –ĺ—ą–ł–Ī–ļ–Ķ –Ņ—Ä–ĺ–ł–Ĺ–ī–Ķ–ļ—Ā–ł—Ä–ĺ–≤–į–Ľ–ł, –Ĺ–į–Ņ—Ä–ł–ľ–Ķ—Ä, –Ī–ĺ–Ľ—Ć—ą–ĺ–Ļ —Ą–į–Ļ–Ľ —Ā –Ľ–ĺ–≥–į–ľ–ł, –ł–Ľ–ł –ļ—É—á—É –Ņ—Ä–ĺ–ľ–Ķ–∂—É—ā–ĺ—á–Ĺ—č—Ö —Ą–į–Ļ–Ľ–ĺ–≤ –ļ–ĺ–ľ–Ņ–ł–Ľ—Ź—Ü–ł–ł. –ß—ā–ĺ–Ī—č —Ā–ī–Ķ–Ľ–į—ā—Ć —ć—ā–ĺ, –ł—Ā–Ņ–ĺ–Ľ—Ć–∑—É–Ļ—ā–Ķ –ĺ–Ņ—Ü–ł—é <code>--cached</code>:</p>

<pre data-type="programlisting" data-code-language="console"><code class="gp">$</code> git rm --cached README
</pre>

<p>–í –ļ–ĺ–ľ–į–Ĺ–ī—É <code>git rm</code> –ľ–ĺ–∂–Ĺ–ĺ –Ņ–Ķ—Ä–Ķ–ī–į–≤–į—ā—Ć —Ą–į–Ļ–Ľ—č, –ļ–į—ā–į–Ľ–ĺ–≥–ł –ł–Ľ–ł glob-—ą–į–Ī–Ľ–ĺ–Ĺ—č. –≠—ā–ĺ –ĺ–∑–Ĺ–į—á–į–Ķ—ā, —á—ā–ĺ –≤—č –ľ–ĺ–∂–Ķ—ā–Ķ –≤—č—ā–≤–ĺ—Ä—Ź—ā—Ć —á—ā–ĺ-—ā–ĺ –≤—Ä–ĺ–ī–Ķ:</p>

<pre data-type="programlisting" data-code-language="console"><code class="gp">$</code> git rm log/<code class="se">\*</code>.log
</pre>

<p>–ě–Ī—Ä–į—ā–ł—ā–Ķ –≤–Ĺ–ł–ľ–į–Ĺ–ł–Ķ –Ĺ–į –ĺ–Ī—Ä–į—ā–Ĺ—č–Ļ —Ā–Ľ—ć—ą (<code>\</code>) –Ņ–Ķ—Ä–Ķ–ī <code>*</code>. –ě–Ĺ –Ĺ–Ķ–ĺ–Ī—Ö–ĺ–ī–ł–ľ –ł–∑-–∑–į —ā–ĺ–≥–ĺ, —á—ā–ĺ Git –ł—Ā–Ņ–ĺ–Ľ—Ć–∑—É–Ķ—ā —Ā–≤–ĺ–Ļ —Ā–ĺ–Ī—Ā—ā–≤–Ķ–Ĺ–Ĺ—č–Ļ –ĺ–Ī—Ä–į–Ī–ĺ—ā—á–ł–ļ –ł–ľ—Ď–Ĺ —Ą–į–Ļ–Ľ–ĺ–≤ –≤–ī–ĺ–Ī–į–≤–ĺ–ļ –ļ –ĺ–Ī—Ä–į–Ī–ĺ—ā—á–ł–ļ—É –≤–į—ą–Ķ–≥–ĺ –ļ–ĺ–ľ–į–Ĺ–ī–Ĺ–ĺ–≥–ĺ –ł–Ĺ—ā–Ķ—Ä–Ņ—Ä–Ķ—ā–į—ā–ĺ—Ä–į. –≠—ā–į –ļ–ĺ–ľ–į–Ĺ–ī–į —É–ī–į–Ľ—Ź–Ķ—ā –≤—Ā–Ķ —Ą–į–Ļ–Ľ—č –ł–ľ–Ķ—é—Č–ł–Ķ —Ä–į—Ā—ą–ł—Ä–Ķ–Ĺ–ł–Ķ <code>.log</code> –Ĺ–į—Ö–ĺ–ī—Ź—Č–ł–Ķ—Ā—Ź –≤ –ī–ł—Ä–Ķ–ļ—ā–ĺ—Ä–ł–ł <code>log/</code>. –ė–Ľ–ł –∂–Ķ –≤—č –ľ–ĺ–∂–Ķ—ā–Ķ —Ā–ī–Ķ–Ľ–į—ā—Ć –≤–ĺ—ā —ā–į–ļ:</p>

<pre data-type="programlisting" data-code-language="console"><code class="gp">$</code> git rm <code class="se">\*</code>~
</pre>

<p>–≠—ā–į –ļ–ĺ–ľ–į–Ĺ–ī–į —É–ī–į–Ľ—Ź–Ķ—ā –≤—Ā–Ķ —Ą–į–Ļ–Ľ—č, —á—Ć–ł –ł–ľ–Ķ–Ĺ–į –∑–į–ļ–į–Ĺ—á–ł–≤–į—é—ā—Ā—Ź –Ĺ–į <code>~</code>.</p>
</section><section data-type="sect2" id="_git_mv"><h3 id="–ü–Ķ—Ä–Ķ–ľ–Ķ—Č–Ķ–Ĺ–ł–Ķ-—Ą–į–Ļ–Ľ–ĺ–≤"><a href="#–ü–Ķ—Ä–Ķ–ľ–Ķ—Č–Ķ–Ĺ–ł–Ķ-—Ą–į–Ļ–Ľ–ĺ–≤">–ü–Ķ—Ä–Ķ–ľ–Ķ—Č–Ķ–Ĺ–ł–Ķ —Ą–į–Ļ–Ľ–ĺ–≤</a></h3>

<p><a data-type="indexterm" data-primary="files" data-secondary="moving" id="id-GRdcJ"></a>
–í –ĺ—ā–Ľ–ł—á–ł–Ķ –ĺ—ā –ľ–Ĺ–ĺ–≥–ł—Ö –ī—Ä—É–≥–ł—Ö —Ā–ł—Ā—ā–Ķ–ľ –≤–Ķ—Ä—Ā–ł–ĺ–Ĺ–Ĺ–ĺ–≥–ĺ –ļ–ĺ–Ĺ—ā—Ä–ĺ–Ľ—Ź, Git –Ĺ–Ķ –ĺ—ā—Ā–Ľ–Ķ–∂–ł–≤–į–Ķ—ā –Ņ–Ķ—Ä–Ķ–ľ–Ķ—Č–Ķ–Ĺ–ł–Ķ —Ą–į–Ļ–Ľ–ĺ–≤ —Ź–≤–Ĺ–ĺ. –ö–ĺ–≥–ī–į –≤—č –Ņ–Ķ—Ä–Ķ–ł–ľ–Ķ–Ĺ–ĺ–≤—č–≤–į–Ķ—ā–Ķ —Ą–į–Ļ–Ľ –≤ Git, –≤ –Ĺ—Ď–ľ –Ĺ–Ķ —Ā–ĺ—Ö—Ä–į–Ĺ—Ź–Ķ—ā—Ā—Ź –Ĺ–ł–ļ–į–ļ–ł—Ö –ľ–Ķ—ā–į–ī–į–Ĺ–Ĺ—č—Ö, –≥–ĺ–≤–ĺ—Ä—Ź—Č–ł—Ö –ĺ —ā–ĺ–ľ, —á—ā–ĺ —Ą–į–Ļ–Ľ –Ī—č–Ľ –Ņ–Ķ—Ä–Ķ–ł–ľ–Ķ–Ĺ–ĺ–≤–į–Ĺ. –ě–ī–Ĺ–į–ļ–ĺ, Git –ī–ĺ–≤–ĺ–Ľ—Ć–Ĺ–ĺ —É–ľ—Ď–Ĺ –≤ –Ņ–Ľ–į–Ĺ–Ķ –ĺ–Ī–Ĺ–į—Ä—É–∂–Ķ–Ĺ–ł—Ź –Ņ–Ķ—Ä–Ķ–ľ–Ķ—Č–Ķ–Ĺ–ł–Ļ –Ņ–ĺ—Ā—ā—Ą–į–ļ—ā—É–ľ ‚ÄĒ –ľ—č —Ä–į—Ā—Ā–ľ–ĺ—ā—Ä–ł–ľ –ĺ–Ī–Ĺ–į—Ä—É–∂–Ķ–Ĺ–ł–Ķ –Ņ–Ķ—Ä–Ķ–ľ–Ķ—Č–Ķ–Ĺ–ł—Ź —Ą–į–Ļ–Ľ–ĺ–≤ —á—É—ā—Ć –Ņ–ĺ–∑–∂–Ķ.</p>

<p>–Ę–į–ļ–ł–ľ –ĺ–Ī—Ä–į–∑–ĺ–ľ, –Ĺ–į–Ľ–ł—á–ł–Ķ –≤ Git –ļ–ĺ–ľ–į–Ĺ–ī—č <code>mv</code> –≤—č–≥–Ľ—Ź–ī–ł—ā –Ĺ–Ķ—Ā–ļ–ĺ–Ľ—Ć–ļ–ĺ —Ā—ā—Ä–į–Ĺ–Ĺ—č–ľ. –ē—Ā–Ľ–ł –≤–į–ľ —Ö–ĺ—á–Ķ—ā—Ā—Ź –Ņ–Ķ—Ä–Ķ–ł–ľ–Ķ–Ĺ–ĺ–≤–į—ā—Ć —Ą–į–Ļ–Ľ –≤ Git, –≤—č –ľ–ĺ–∂–Ķ—ā–Ķ —Ā–ī–Ķ–Ľ–į—ā—Ć —á—ā–ĺ-—ā–ĺ –≤—Ä–ĺ–ī–Ķ:</p>

<pre data-type="programlisting" data-code-language="console"><code class="gp">$</code> git mv file_from file_to
</pre>

<p>–ł —ć—ā–ĺ –ĺ—ā–Ľ–ł—á–Ĺ–ĺ —Ā—Ä–į–Ī–ĺ—ā–į–Ķ—ā. –Ě–į —Ā–į–ľ–ĺ–ľ –ī–Ķ–Ľ–Ķ, –Ķ—Ā–Ľ–ł –≤—č –≤—č–Ņ–ĺ–Ľ–Ĺ–ł—ā–Ķ —á—ā–ĺ-—ā–ĺ –≤—Ä–ĺ–ī–Ķ —ć—ā–ĺ–≥–ĺ –ł –Ņ–ĺ—Ā–ľ–ĺ—ā—Ä–ł—ā–Ķ –Ĺ–į —Ā—ā–į—ā—É—Ā, –≤—č —É–≤–ł–ī–ł—ā–Ķ, —á—ā–ĺ Git —Ā—á–ł—ā–į–Ķ—ā, —á—ā–ĺ –Ņ—Ä–ĺ–ł–∑–ĺ—ą–Ľ–ĺ –Ņ–Ķ—Ä–Ķ–ł–ľ–Ķ–Ĺ–ĺ–≤–į–Ĺ–ł–Ķ —Ą–į–Ļ–Ľ–į:</p>

<pre data-type="programlisting" data-code-language="console"><code class="gp">$</code> git mv README.md README
<code class="gp">$</code> git status
<code class="go">On branch master</code>
<code class="go">Changes to be committed:</code>
<code class="go">  (use "git reset HEAD &lt;file&gt;..." to unstage)</code>

<code class="go">    renamed:    README.md -&gt; README</code>
</pre>

<p>–ě–ī–Ĺ–į–ļ–ĺ, —ć—ā–ĺ —ć–ļ–≤–ł–≤–į–Ľ–Ķ–Ĺ—ā–Ĺ–ĺ –≤—č–Ņ–ĺ–Ľ–Ĺ–Ķ–Ĺ–ł—é —Ā–Ľ–Ķ–ī—É—é—Č–ł—Ö –ļ–ĺ–ľ–į–Ĺ–ī:</p>

<pre data-type="programlisting" data-code-language="console"><code class="gp">$</code> mv README.md README
<code class="gp">$</code> git rm README.md
<code class="gp">$</code> git add README
</pre>

<p>Git –Ĺ–Ķ—Ź–≤–Ĺ–ĺ –ĺ–Ņ—Ä–Ķ–ī–Ķ–Ľ—Ź–Ķ—ā, —á—ā–ĺ –Ņ—Ä–ĺ–ł–∑–ĺ—ą–Ľ–ĺ –Ņ–Ķ—Ä–Ķ–ł–ľ–Ķ–Ĺ–ĺ–≤–į–Ĺ–ł–Ķ, –Ņ–ĺ—ć—ā–ĺ–ľ—É –Ĺ–Ķ–≤–į–∂–Ĺ–ĺ, –Ņ–Ķ—Ä–Ķ–ł–ľ–Ķ–Ĺ—É–Ķ—ā–Ķ –≤—č —Ą–į–Ļ–Ľ —ā–į–ļ –ł–Ľ–ł –ł—Ā–Ņ–ĺ–Ľ—Ć–∑—É—Ź –ļ–ĺ–ľ–į–Ĺ–ī—É <code>mv</code>. –ē–ī–ł–Ĺ—Ā—ā–≤–Ķ–Ĺ–Ĺ–ĺ–Ķ –ĺ—ā–Ľ–ł—á–ł–Ķ —Ā–ĺ—Ā—ā–ĺ–ł—ā –Ľ–ł—ą—Ć –≤ —ā–ĺ–ľ, —á—ā–ĺ <code>mv</code> ‚ÄĒ —ć—ā–ĺ –ĺ–ī–Ĺ–į –ļ–ĺ–ľ–į–Ĺ–ī–į –≤–ľ–Ķ—Ā—ā–ĺ —ā—Ä—Ď—Ö ‚ÄĒ —ć—ā–ĺ —Ą—É–Ĺ–ļ—Ü–ł—Ź –ī–Ľ—Ź —É–ī–ĺ–Ī—Ā—ā–≤–į. –í–į–∂–Ĺ–Ķ–Ķ –ī—Ä—É–≥–ĺ–Ķ ‚ÄĒ –≤—č –ľ–ĺ–∂–Ķ—ā–Ķ –ł—Ā–Ņ–ĺ–Ľ—Ć–∑–ĺ–≤–į—ā—Ć –Ľ—é–Ī–ĺ–Ļ —É–ī–ĺ–Ī–Ĺ—č–Ļ —Ā–Ņ–ĺ—Ā–ĺ–Ī, —á—ā–ĺ–Ī—č –Ņ–Ķ—Ä–Ķ–ł–ľ–Ķ–Ĺ–ĺ–≤–į—ā—Ć —Ą–į–Ļ–Ľ, –ł –∑–į—ā–Ķ–ľ –≤–ĺ—Ā–Ņ–ĺ–Ľ—Ć–∑–ĺ–≤–į—ā—Ć—Ā—Ź add/rm –Ņ–Ķ—Ä–Ķ–ī –ļ–ĺ–ľ–ľ–ł—ā–ĺ–ľ.</p>
