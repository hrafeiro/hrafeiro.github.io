    <h1>5.1 –†–∞—Б–њ—А–µ–і–µ–ї—С–љ–љ—Л–є Git - –†–∞—Б–њ—А–µ–і–µ–ї—С–љ–љ—Л–µ —А–∞–±–Њ—З–Є–µ –њ—А–Њ—Ж–µ—Б—Б—Л</h1>
  <div><h2>–†–∞—Б–њ—А–µ–і–µ–ї—С–љ–љ—Л–µ —А–∞–±–Њ—З–Є–µ –њ—А–Њ—Ж–µ—Б—Б—Л</h2>

<p>–Т –Њ—В–ї–Є—З–Є–µ –Њ—В —Ж–µ–љ—В—А–∞–ї–Є–Ј–Њ–≤–∞–љ–љ—Л—Е —Б–Є—Б—В–µ–Љ –Ї–Њ–љ—В—А–Њ–ї—П –≤–µ—А—Б–Є–є, —А–∞—Б–њ—А–µ–і–µ–ї—С–љ–љ–∞—П –њ—А–Є—А–Њ–і–∞ Git&#39;–∞ –њ–Њ–Ј–≤–Њ–ї—П–µ—В –≤–∞–Љ –±—Л—В—М –≥–Њ—А–∞–Ј–і–Њ –±–Њ–ї–µ–µ –≥–Є–±–Ї–Є–Љ –≤ –Њ—В–љ–Њ—И–µ–љ–Є–Є —Г—З–∞—Б—В–Є—П —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї–Њ–≤ –≤ —А–∞–±–Њ—В–µ –љ–∞–і –њ—А–Њ–µ–Ї—В–∞–Љ–Є. –Т —Ж–µ–љ—В—А–∞–ї–Є–Ј–Њ–≤–∞–љ–љ—Л—Е —Б–Є—Б—В–µ–Љ–∞—Е –≤—Б–µ —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї–Є —П–≤–ї—П—О—В—Б—П —Г–Ј–ї–∞–Љ–Є —Б–µ—В–Є, –±–Њ–ї–µ–µ –Є–ї–Є –Љ–µ–љ–µ–µ –Њ–і–Є–љ–∞–Ї–Њ–≤–Њ —А–∞–±–Њ—В–∞—О—Й–Є–Љ–Є –љ–∞ —Ж–µ–љ—В—А–∞–ї—М–љ–Њ–Љ —Е–∞–±–µ. –Ю–і–љ–∞–Ї–Њ, –≤ Git&#39;–µ –Ї–∞–ґ–і—Л–є —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї –њ–Њ—В–µ–љ—Ж–Є–∞–ї—М–љ–Њ —П–≤–ї—П–µ—В—Б—П –Є —Г–Ј–ї–Њ–Љ, –Є —Е–∞–±–Њ–Љ. –Ґ–Њ –µ—Б—В—М –Ї–∞–ґ–і—Л–є —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї –Љ–Њ–ґ–µ—В –Ї–∞–Ї –≤–љ–Њ—Б–Є—В—М –Ї–Њ–і –≤ –і—А—Г–≥–Є–µ —А–µ–њ–Њ–Ј–Є—В–Њ—А–Є–Є, —В–∞–Ї –Є —Б–Њ–і–µ—А–ґ–∞—В—М –њ—Г–±–ї–Є—З–љ—Л–є —А–µ–њ–Њ–Ј–Є—В–Њ—А–Є–є, –љ–∞ –Њ—Б–љ–Њ–≤–µ –Ї–Њ—В–Њ—А–Њ–≥–Њ —А–∞–±–Њ—В–∞—О—В –і—А—Г–≥–Є–µ —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї–Є, –Є –≤ –Ї–Њ—В–Њ—А—Л–є –Њ–љ–Є –≤–љ–Њ—Б—П—В —Б–≤–Њ–Є –Є–Ј–Љ–µ–љ–µ–љ–Є—П. –≠—В–Њ –і–∞—С—В –≤–∞—И–µ–є –Ї–Њ–Љ–∞–љ–і–µ –≤–Њ–Ј–Љ–Њ–ґ–љ–Њ—Б—В—М –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞—В—М –ї—О–±–Њ–є –Є–Ј –Љ–љ–Њ–ґ–µ—Б—В–≤–∞ —А–∞–Ј–ї–Є—З–љ—Л—Е —Б–њ–Њ—Б–Њ–±–Њ–≤ –Њ—Б—Г—Й–µ—Б—В–≤–ї–µ–љ–Є—П —А–∞–±–Њ—З–µ–≥–Њ –њ—А–Њ—Ж–µ—Б—Б–∞ –≤ –≤–∞—И–Є—Е –њ—А–Њ–µ–Ї—В–∞—Е, –њ–Њ—Н—В–Њ–Љ—Г –Љ—Л —А–∞—Б—Б–Љ–Њ—В—А–Є–Љ –љ–µ—Б–Ї–Њ–ї—М–Ї–Њ —А–∞—Б–њ—А–Њ—Б—В—А–∞–љ—С–љ–љ—Л—Е –њ–Њ–і—Е–Њ–і–Њ–≤, –њ–Њ–ї—М–Ј—Г—О—Й–Є—Е—Б—П –≥–Є–±–Ї–Њ—Б—В—М—О Git&#39;–∞. –Ь—Л —А–∞—Б—Б–Љ–Њ—В—А–Є–Љ —Б–Є–ї—М–љ—Л–µ —Б—В–Њ—А–Њ–љ—Л –Є –≤–Њ–Ј–Љ–Њ–ґ–љ—Л–µ –љ–µ–і–Њ—Б—В–∞—В–Ї–Є –Ї–∞–ґ–і–Њ–≥–Њ –њ–Њ–і—Е–Њ–і–∞; –≤—Л –Љ–Њ–ґ–µ—В–µ –≤—Л–±—А–∞—В—М –і–ї—П —Б–µ–±—П –Њ–і–Є–љ –Є–Ј –љ–Є—Е, –∞ –Љ–Њ–ґ–µ—В–µ —Б–Њ–≤–Љ–µ—Б—В–Є—В—М –Њ—Б–Њ–±–µ–љ–љ–Њ—Б—В–Є —Б—А–∞–Ј—Г –љ–µ—Б–Ї–Њ–ї—М–Ї–Є—Е –њ–Њ–і—Е–Њ–і–Њ–≤.</p>

<h3 id="–¶–µ–љ—В—А–∞–ї–Є–Ј–Њ–≤–∞–љ–љ—Л–є-—А–∞–±–Њ—З–Є–є-–њ—А–Њ—Ж–µ—Б—Б"><a href="#–¶–µ–љ—В—А–∞–ї–Є–Ј–Њ–≤–∞–љ–љ—Л–є-—А–∞–±–Њ—З–Є–є-–њ—А–Њ—Ж–µ—Б—Б">–¶–µ–љ—В—А–∞–ї–Є–Ј–Њ–≤–∞–љ–љ—Л–є —А–∞–±–Њ—З–Є–є –њ—А–Њ—Ж–µ—Б—Б</a></h3>

<p>–Т —Ж–µ–љ—В—А–∞–ї–Є–Ј–Њ–≤–∞–љ–љ—Л—Е —Б–Є—Б—В–µ–Љ–∞—Е —Б—Г—Й–µ—Б—В–≤—Г–µ—В, –Ї–∞–Ї –њ—А–∞–≤–Є–ї–Њ, –Њ–і–љ–∞ –Љ–Њ–і–µ–ї—М —Б–Њ–≤–Љ–µ—Б—В–љ–Њ–є —А–∞–Ј—А–∞–±–Њ—В–Ї–Є вАФ —Ж–µ–љ—В—А–∞–ї–Є–Ј–Њ–≤–∞–љ–љ—Л–є —А–∞–±–Њ—З–Є–є –њ—А–Њ—Ж–µ—Б—Б. –Ю–і–Є–љ —Ж–µ–љ—В—А–∞–ї—М–љ—Л–є —Е–∞–±, –Є–ї–Є —А–µ–њ–Њ–Ј–Є—В–Њ—А–Є–є, –Љ–Њ–ґ–µ—В –њ—А–Є–љ–Є–Љ–∞—В—М –Ї–Њ–і, –∞ –≤—Б–µ –Њ—Б—В–∞–ї—М–љ—Л–µ —Б–Є–љ—Е—А–Њ–љ–Є–Ј–Є—А—Г—О—В —Б–≤–Њ—О —А–∞–±–Њ—В—Г —Б –љ–Є–Љ. –Э–µ–Ї–Њ—В–Њ—А–Њ–µ —З–Є—Б–ї–Њ —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї–Њ–≤ —П–≤–ї—П—О—В—Б—П —Г–Ј–ї–∞–Љ–Є вАФ –Ї–ї–Є–µ–љ—В–∞–Љ–Є —Н—В–Њ–≥–Њ —Е–∞–±–∞ вАФ –Є —Б–Є–љ—Е—А–Њ–љ–Є–Ј–Є—А—Г—О—В—Б—П —Б –љ–Є–Љ –Њ–і–љ–Є–Љ (—Б–Љ. —А–Є—Б. 5-1).</p>

<p><center><img src="/figures/18333fig0501-tn.png"></center><br/>
–†–Є—Б—Г–љ–Њ–Ї 5-1. –¶–µ–љ—В—А–∞–ї–Є–Ј–Њ–≤–∞–љ–љ—Л–є —А–∞–±–Њ—З–Є–є –њ—А–Њ—Ж–µ—Б—Б.</p>

<p>–≠—В–Њ –Ј–љ–∞—З–Є—В, —З—В–Њ –µ—Б–ї–Є –і–≤–∞ —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї–∞ –≤—Л–њ–Њ–ї–љ—П—О—В –Ї–ї–Њ–љ–Є—А–Њ–≤–∞–љ–Є–µ —Б —Е–∞–±–∞ –Є –Њ–±–∞ –і–µ–ї–∞—О—В –Є–Ј–Љ–µ–љ–µ–љ–Є—П –≤ –њ—А–Њ–µ–Ї—В–µ, —В–Њ –њ–µ—А–≤—Л–є –Є–Ј –љ–Є—Е, –Ї—В–Њ –Њ—В–њ—А–∞–≤–Є—В —Б–≤–Њ–Є –Є–Ј–Љ–µ–љ–µ–љ–Є—П –Њ–±—А–∞—В–љ–Њ –љ–∞ —Е–∞–±, —Б–і–µ–ї–∞–µ—В —Н—В–Њ –±–µ–Ј –њ—А–Њ–±–ї–µ–Љ. –Т—В–Њ—А–Њ–є —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї –і–Њ–ї–ґ–µ–љ –≤–Ј—П—В—М –љ–∞—А–∞–±–Њ—В–Ї–Є –њ–µ—А–≤–Њ–≥–Њ –Є –≤—Л–њ–Њ–ї–љ–Є—В—М —Б–ї–Є—П–љ–Є–µ –њ–µ—А–µ–і —В–µ–Љ, –Ї–∞–Ї –Њ—В–њ—А–∞–≤–Є—В—М —Б–≤–Њ–Є –Є–Ј–Љ–µ–љ–µ–љ–Є—П, —В–∞–Ї —З—В–Њ–±—Л –љ–µ –њ–µ—А–µ–Ј–∞–њ–Є—Б–∞—В—М –Є–Ј–Љ–µ–љ–µ–љ–Є—П –њ–µ—А–≤–Њ–≥–Њ —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї–∞. –≠—В–Њ—В –њ—А–Є–љ—Ж–Є–њ —Б–њ—А–∞–≤–µ–і–ї–Є–≤ –і–ї—П Git&#39;–∞ —В–Њ—З–љ–Њ —В–∞–Ї –ґ–µ, –Ї–∞–Ї –Є –і–ї—П Subversion (–Є–ї–Є –ї—О–±–Њ–є –і—А—Г–≥–Њ–є –¶–°–Ъ–Т), –Є –≤ Git&#39;–µ —В–∞–Ї–∞—П –Љ–Њ–і–µ–ї—М —А–∞–±–Њ—В–∞–µ—В –Њ—В–ї–Є—З–љ–Њ.</p>

<p>–Х—Б–ї–Є —Г –≤–∞—Б –љ–µ–±–Њ–ї—М—И–∞—П –Ї–Њ–Љ–∞–љ–і–∞ –Є–ї–Є –≤–∞—Б –њ–Њ–ї–љ–Њ—Б—В—М—О —Г—Б—В—А–∞–Є–≤–∞–µ—В —А–∞–±–Њ—З–Є–є –њ—А–Њ—Ж–µ—Б—Б —Ж–µ–љ—В—А–∞–ї–Є–Ј–Њ–≤–∞–љ–љ–Њ–≥–Њ —В–Є–њ–∞, –њ—А–Є–Љ–µ–љ—П–µ–Љ—Л–є –≤ –≤–∞—И–µ–є –Ї–Њ–Љ–њ–∞–љ–Є–Є, –≤—Л –Љ–Њ–ґ–µ—В–µ –њ—А–Њ—Б—В–Њ –њ—А–Њ–і–Њ–ї–ґ–Є—В—М –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞—В—М —В–∞–Ї–Њ–є —А–∞–±–Њ—З–Є–є –њ—А–Њ—Ж–µ—Б—Б –Є –≤ Git&#39;–µ. –Я—А–Њ—Б—В–Њ –љ–∞—Б—В—А–Њ–є—В–µ –Њ–і–Є–љ —А–µ–њ–Њ–Ј–Є—В–Њ—А–Є–є –Є –і–∞–є—В–µ –Ї–∞–ґ–і–Њ–Љ—Г –≤ –≤–∞—И–µ–є –Ї–Њ–Љ–∞–љ–і–µ –њ—А–∞–≤–∞ –љ–∞ –Њ—В–њ—А–∞–≤–Ї—Г –Є–Ј–Љ–µ–љ–µ–љ–Є–є; Git –љ–µ –њ–Њ–Ј–≤–Њ–ї–Є—В –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—П–Љ –њ–µ—А–µ–Ј–∞–њ–Є—Б—Л–≤–∞—В—М –љ–∞—А–∞–±–Њ—В–Ї–Є –і—А—Г–≥ –і—А—Г–≥–∞. –Х—Б–ї–Є –Ї–∞–Ї–Њ–є-—В–Њ —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї —Б–Ї–ї–Њ–љ–Є—А—Г–µ—В —А–µ–њ–Њ–Ј–Є—В–Њ—А–Є–є, —Б–і–µ–ї–∞–µ—В –≤ –љ—С–Љ –Є–Ј–Љ–µ–љ–µ–љ–Є—П, –∞ –Ј–∞—В–µ–Љ –њ–Њ–њ—Л—В–∞–µ—В—Б—П –≤—Л–ї–Њ–ґ–Є—В—М —Н—В–Є –Є–Ј–Љ–µ–љ–µ–љ–Є—П, –≤ —В–Њ –≤—А–µ–Љ—П –Ї–∞–Ї –і—А—Г–≥–Њ–є —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї —Г–ґ–µ —Г—Б–њ–µ–ї –Њ—В–њ—А–∞–≤–Є—В—М —Б–≤–Њ–Є, —Б–µ—А–≤–µ—А –Њ—В–Ї–ї–Њ–љ–Є—В –Є–Ј–Љ–µ–љ–µ–љ–Є—П —Н—В–Њ–≥–Њ —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї–∞. –Х–Љ—Г –±—Г–і–µ—В —Б–Ї–∞–Ј–∞–љ–Њ, —З—В–Њ –Њ–љ –њ—Л—В–∞–µ—В—Б—П –≤—Л–ї–Њ–ґ–Є—В—М –Є–Ј–Љ–µ–љ–µ–љ–Є—П, –і–ї—П –Ї–Њ—В–Њ—А—Л—Е –љ–µ–≤–Њ–Ј–Љ–Њ–ґ–љ–Њ –≤—Л–њ–Њ–ї–љ–Є—В—М –њ–µ—А–µ–Љ–Њ—В–Ї—Г (fast-forward), –Є —З—В–Њ –љ–∞–і–Њ —Б–љ–∞—З–∞–ї–∞ –Є–Ј–≤–ї–µ—З—М –і–∞–љ–љ—Л–µ —Б —Б–µ—А–≤–µ—А–∞, –≤—Л–њ–Њ–ї–љ–Є—В—М —Б–ї–Є—П–љ–Є–µ, –∞ —Г–ґ–µ –њ–Њ—В–Њ–Љ –Њ—В–њ—А–∞–≤–ї—П—В—М —Б–≤–Њ–Є –Є–Ј–Љ–µ–љ–µ–љ–Є—П. –Ґ–∞–Ї–Њ–є —А–∞–±–Њ—З–Є–є –њ—А–Њ—Ж–µ—Б—Б –њ—А–Є–≤–ї–µ–Ї–∞—В–µ–ї–µ–љ –і–ї—П –±–Њ–ї—М—И–Њ–≥–Њ –Ї–Њ–ї–Є—З–µ—Б—В–≤–∞ –ї—О–і–µ–є, —В–∞–Ї –Ї–∞–Ї —Н—В–Њ —В–∞ –Љ–Њ–і–µ–ї—М, —Б –Ї–Њ—В–Њ—А–Њ–є –Љ–љ–Њ–≥–Є–µ –Ј–љ–∞–Ї–Њ–Љ—Л –Є –Ї–Њ—В–Њ—А–∞—П –Љ–љ–Њ–≥–Є–Љ –њ–Њ–љ—П—В–љ–∞.</p>

<h3 id="–†–∞–±–Њ—З–Є–є-–њ—А–Њ—Ж–µ—Б—Б-—Б-–Љ–µ–љ–µ–і–ґ–µ—А–Њ–Љ-–њ–Њ-–Є–љ—В–µ–≥—А–∞—Ж–Є–Є"><a href="#–†–∞–±–Њ—З–Є–є-–њ—А–Њ—Ж–µ—Б—Б-—Б-–Љ–µ–љ–µ–і–ґ–µ—А–Њ–Љ-–њ–Њ-–Є–љ—В–µ–≥—А–∞—Ж–Є–Є">–†–∞–±–Њ—З–Є–є –њ—А–Њ—Ж–µ—Б—Б —Б –Љ–µ–љ–µ–і–ґ–µ—А–Њ–Љ –њ–Њ –Є–љ—В–µ–≥—А–∞—Ж–Є–Є</a></h3>

<p>–Ґ–∞–Ї –Ї–∞–Ї Git –њ–Њ–Ј–≤–Њ–ї—П–µ—В –Є–Љ–µ—В—М –љ–µ—Б–Ї–Њ–ї—М–Ї–Њ —Г–і–∞–ї—С–љ–љ—Л—Е —А–µ–њ–Њ–Ј–Є—В–Њ—А–Є–µ–≤, —Б—Г—Й–µ—Б—В–≤—Г–µ—В –≤–Њ–Ј–Љ–Њ–ґ–љ–Њ—Б—В—М –≤–µ–і–µ–љ–Є—П —В–∞–Ї–Њ–≥–Њ —А–∞–±–Њ—З–µ–≥–Њ –њ—А–Њ—Ж–µ—Б—Б–∞, –њ—А–Є –Ї–Њ—В–Њ—А–Њ–Љ –Ї–∞–ґ–і—Л–є —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї –Є–Љ–µ–µ—В –њ—А–∞–≤–∞ –љ–∞ –Ј–∞–њ–Є—Б—М –≤ —Б–≤–Њ–є —Б–Њ–±—Б—В–≤–µ–љ–љ—Л–є –њ—Г–±–ї–Є—З–љ—Л–є —А–µ–њ–Њ–Ј–Є—В–Њ—А–Є–є –Є –њ—А–∞–≤–∞ –љ–∞ —З—В–µ–љ–Є–µ –і–ї—П –≤—Б–µ—Е –Њ—Б—В–∞–ї—М–љ—Л—Е. –≠—В–Њ—В —Б—Ж–µ–љ–∞—А–Є–є —З–∞—Б—В–Њ –њ–Њ–і—А–∞–Ј—Г–Љ–µ–≤–∞–µ—В —Б—Г—Й–µ—Б—В–≤–Њ–≤–∞–љ–Є–µ –Ї–∞–љ–Њ–љ–Є—З–µ—Б–Ї–Њ–≥–Њ —А–µ–њ–Њ–Ј–Є—В–Њ—А–Є—П, –Ї–Њ—В–Њ—А—Л–є –њ—А–µ–і—Б—В–∞–≤–ї—П–µ—В —Б–Њ–±–Њ–є &quot;–Њ—Д–Є—Ж–Є–∞–ї—М–љ—Л–є&quot; –њ—А–Њ–µ–Ї—В. –І—В–Њ–±—Л –њ—А–Є–љ—П—В—М —Г—З–∞—Б—В–Є–µ –≤ —А–∞–±–Њ—В–µ –љ–∞–і —Н—В–Є–Љ –њ—А–Њ–µ–Ї—В–Њ–Љ, –љ–∞–і–Њ —Б–Њ–Ј–і–∞—В—М —Б–≤–Њ—О —Б–Њ–±—Б—В–≤–µ–љ–љ—Г—О –њ—Г–±–ї–Є—З–љ—Г—О –Ї–Њ–њ–Є—О –њ—А–Њ–µ–Ї—В–∞ –Є –≤—Л–ї–Њ–ґ–Є—В—М —В—Г–і–∞ —Б–≤–Њ–Є –Є–Ј–Љ–µ–љ–µ–љ–Є—П. –Я–Њ—В–Њ–Љ –≤—Л –Љ–Њ–ґ–µ—В–µ –Њ—В–њ—А–∞–≤–Є—В—М –Ј–∞–њ—А–Њ—Б –≤–ї–∞–і–µ–ї—М—Ж—Г –Њ—Б–љ–Њ–≤–љ–Њ–≥–Њ –њ—А–Њ–µ–Ї—В–∞ –љ–∞ –≤–љ–µ—Б–µ–љ–Є–µ –≤ –љ–µ–≥–Њ –≤–∞—И–Є—Е –Є–Ј–Љ–µ–љ–µ–љ–Є–є. –Ю–љ –Љ–Њ–ґ–µ—В –і–Њ–±–∞–≤–Є—В—М –≤–∞—И —А–µ–њ–Њ–Ј–Є—В–Њ—А–Є–є –≤ –Ї–∞—З–µ—Б—В–≤–µ —Г–і–∞–ї—С–љ–љ–Њ–≥–Њ, –њ—А–Њ—В–µ—Б—В–Є—А–Њ–≤–∞—В—М –ї–Њ–Ї–∞–ї—М–љ–Њ –≤–∞—И–Є –Є–Ј–Љ–µ–љ–µ–љ–Є—П, —Б–ї–Є—В—М –Є—Е —Б–Њ —Б–≤–Њ–µ–є –≤–µ—В–Ї–Њ–є –Є –Ј–∞—В–µ–Љ –Њ—В–њ—А–∞–≤–Є—В—М –Њ–±—А–∞—В–љ–Њ –≤ –њ—Г–±–ї–Є—З–љ—Л–є —А–µ–њ–Њ–Ј–Є—В–Њ—А–Є–є. –≠—В–Њ—В –њ—А–Њ—Ж–µ—Б—Б –Њ—Б—Г—Й–µ—Б—В–≤–ї—П–µ—В—Б—П —Б–ї–µ–і—Г—О—Й–Є–Љ –Њ–±—А–∞–Ј–Њ–Љ (—Б–Љ. —А–Є—Б. 5-2):</p>

