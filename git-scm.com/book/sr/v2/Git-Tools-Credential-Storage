    <code class="n">prot</code><code class="p">,</code><code class="n">user</code><code class="p">,</code><code class="n">pass</code><code class="p">,</code><code class="n">host</code> <code class="o">=</code> <code class="n">fileline</code><code class="o">.</code><code class="n">scan</code><code class="p">(</code><code class="sr">/^(.*?):\/\/(.*?):(.*?)@(.*)$/</code><code class="p">)</code><code class="o">.</code><code class="n">first</code>
