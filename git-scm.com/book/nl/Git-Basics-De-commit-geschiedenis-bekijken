<th width="20%">Optie</th>
<th>Omschrijving van de Output</th>
</tr></thead>
<tbody>
<tr>
<td><p><code>%H</code></p></td>
<td><p>Commit hash</p></td>
</tr>
<tr>
<td><p><code>%h</code></p></td>
<td><p>Afgekorte commit hash</p></td>
</tr>
<tr>
<td><p><code>%T</code></p></td>
<td><p>Tree hash</p></td>
</tr>
<tr>
<td><p><code>%t</code></p></td>
<td><p>Afgekorte tree hash</p></td>
</tr>
<tr>
<td><p><code>%P</code></p></td>
<td><p>Parent hashes</p></td>
</tr>
<tr>
<td><p><code>%p</code></p></td>
