    </code><code class="ss">:tree</code><code> </code><code class="o">=</code><code class="o">&gt;</code><code> </code><code class="n">index</code><code class="o">.</code><code class="n">write_tree</code><code class="p">(</code><code class="n">repo</code><code class="p">)</code><code class="p">,</code><code> </code><a class="co" id="co_git_in_je_applicaties_inbouwen_CO1-3" href="ch00/callout_git_in_je_applicaties_inbouwen_CO1-3"><img src="/book/en/v2/book/B-embedding-git/../../callouts/3.png" alt="3"></a><code>
