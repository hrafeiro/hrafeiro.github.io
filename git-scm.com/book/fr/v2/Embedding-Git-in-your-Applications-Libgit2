</code><code class="n">index</code><code class="o">.</code><code class="n">add</code><code class="p">(</code><code class="ss">:path</code><code> </code><code class="o">=</code><code class="o">&gt;</code><code> </code><code class="s1">'newfile.txt'</code><code class="p">,</code><code> </code><code class="ss">:oid</code><code> </code><code class="o">=</code><code class="o">&gt;</code><code> </code><code class="n">blob_id</code><code class="p">)</code><code> </code><a class="co" id="co_embedding_git_in_your_applications_CO1-2" href="ch00/callout_embedding_git_in_your_applications_CO1-2"><img src="/book/en/v2/book/B-embedding-git/../../callouts/2.png" alt="2"></a><code>

