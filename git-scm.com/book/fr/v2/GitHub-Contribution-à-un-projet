$ sed -i '' 's/1000/3000/' blink.ino <a class="co" id="co_github_CO1-3" href="ch00/callout_github_CO1-3"><img src="/book/en/v2/book/06-github/callouts/3.png" alt="3"></a>

$ git diff --word-diff <a class="co" id="co_github_CO1-4" href="ch00/callout_github_CO1-4"><img src="/book/en/v2/book/06-github/callouts/4.png" alt="4"></a>
